// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  ADMIN
}

enum RideState {
  REQUESTED
  ACCEPTED
  DRIVER_ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum VehicleType {
  ECONOMY
  COMFORT
  XL
}

enum TokenType {
  REFRESH
  EMAIL
  PASSWORD
}

enum TokenState {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum PaymentMethod {
  CASH
  CARD
  USSD
  TRANSFER
}

enum DriverApprovalState {
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum PaymentState {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

model User {
  userId          Int            @id @default(autoincrement()) @map("user_id")
  email           String         @unique
  password        String
  name            String
  phone           String?
  role            UserRole
  version         Int            @default(1)
  emailVerifiedAt DateTime?      @map("email_verified_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  tokens          Token[]
  driverProfile   DriverProfile?
  riderProfile    RiderProfile?

  @@map("users")
}

model Token {
  tokenid   Int        @id @default(autoincrement()) @map("token_id")
  userId    Int        @map("user_id")
  token     String     @unique
  type      TokenType
  state     TokenState @default(ACTIVE)
  expiresAt DateTime   @map("expires_at")
  usedAt    DateTime?  @map("used_at")
  ipAddress String?    @map("ip_address")
  userAgent String?    @map("user_agent")
  createdAt DateTime   @default(now()) @map("created_at")
  user      User       @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([type, state])
  @@map("tokens")
}

model DriverProfile {
  driverProfileId        Int                 @id @default(autoincrement()) @map("driver_profile_id")
  userId                 Int                 @unique @map("user_id")
  licenseNumber          String              @unique @map("license_number")
  vehicleType            VehicleType         @map("vehicle_type")
  vehicleMake            String              @map("vehicle_make")
  vehicleModel           String              @map("vehicle_model")
  vehiclePlate           String              @unique @map("vehicle_plate")
  vehicleYear            Int                 @map("vehicle_year")
  isAvailable            Boolean             @default(false) @map("is_available")
  approvalState          DriverApprovalState @default(PENDING_REVIEW) @map("approval_state")
  paystackSubaccountCode String?             @map("paystack_subaccount_code")
  rating                 Float               @default(5.0)
  totalRides             Int                 @default(0) @map("total_rides")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  location DriverLocation?
  rides    Ride[]

  @@map("driver_profiles")
}

model DriverLocation {
  locationId      Int      @id @default(autoincrement()) @map("locatiion_id")
  driverProfileId Int      @unique @map("driver_profile_id")
  lat             Float
  lng             Float
  heading         Float?
  updatedAt       DateTime @updatedAt @map("updated_at")

  driver DriverProfile @relation(fields: [driverProfileId], references: [driverProfileId], onDelete: Cascade)

  @@map("driver_locations")
}

model RiderProfile {
  riderProfileId            Int      @id @default(autoincrement()) @map("rider_profile_id")
  userId                    Int      @unique @map("user_id")
  paystackAuthorizationCode String?  @map("paystack_authorization_code")
  paystackEmail             String?  @map("paystack_email")
  rating                    Float    @default(5.0)
  totalRides                Int      @default(0) @map("total_rides")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  rides Ride[]

  @@map("rider_profiles")
}

model Ride {
  rideId             Int           @id @default(autoincrement()) @map("ride_id")
  riderId            Int           @map("rider_id")
  driverProfileId    Int?          @map("driver_profile_id") // null until a driver accepts
  state              RideState     @default(REQUESTED)
  pickupAddress      String        @map("pickup_address")
  pickupLat          Float         @map("pickup_lat")
  pickupLng          Float         @map("pickup_lng")
  dropoffAddress     String        @map("dropoff_address")
  dropoffLat         Float         @map("dropoff_lat")
  dropoffLng         Float         @map("dropoff_lng")
  vehicleType        VehicleType   @map("vehicle_type")
  paymentMethod      PaymentMethod @map("payment_method")
  estimatedFare      Float         @map("estimated_fare")
  finalFare          Float?        @map("final_fare") // set on completion
  cancellationReason String?       @map("cancellation_reason")
  requestedAt        DateTime      @default(now()) @map("requested_at")
  acceptedAt         DateTime?     @map("accepted_at")
  pickupAt           DateTime?     @map("pickup_at")
  completedAt        DateTime?     @map("completed_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  rider            RiderProfile          @relation(fields: [riderId], references: [riderProfileId])
  driver           DriverProfile?        @relation(fields: [driverProfileId], references: [driverProfileId])
  stateTransitions RideStateTransition[]
  payment          Payment?

  @@index([riderId])
  @@index([driverProfileId])
  @@index([state])
  @@map("rides")
}

model RideStateTransition {
  id          Int        @id @default(autoincrement())
  rideId      Int        @map("ride_id")
  fromState   RideState? @map("from_state")
  toState     RideState  @map("to_state")
  reason      String?
  performedBy Int?       @map("performed_by")
  createdAt   DateTime   @default(now()) @map("created_at")

  ride Ride @relation(fields: [rideId], references: [rideId], onDelete: Cascade)

  @@index([rideId])
  @@map("ride_state_transitions")
}

model Payment {
  paymentId         Int           @id @default(autoincrement()) @map("payment_id")
  rideId            Int           @unique @map("ride_id")
  amount            Float
  method            PaymentMethod
  state             PaymentState  @default(PENDING)
  paystackReference String?       @map("paystack_reference")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  ride Ride @relation(fields: [rideId], references: [rideId])

  @@map("payments")
}
